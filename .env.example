# ─────────────────────────────────────────────────────────────
# Agent Stack — NestJS + Angular
# Copia este archivo como .env y completa los valores
# ─────────────────────────────────────────────────────────────

# ── Entorno ───────────────────────────────────────────────────
ENVIRONMENT=dev           # dev | qa | prd
NODE_ENV=development

# Database TypeORM (MySQL/MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=gymtracker
DB_ROOT_PASSWORD=root

# ── NestJS Backend ────────────────────────────────────────────
BACKEND_CONTAINER_NAME=nestjs-backend
BACKEND_IMAGE=nestjs-backend:latest
BACKEND_PORT=3600

# JWT — access token (corto: 15m, 30m)
JWT_SECRET=cambia-esto-por-un-secreto-aleatorio-largo
JWT_EXPIRES_IN=15m

# JWT — refresh token (largo: 7d, 30d)
JWT_REFRESH_SECRET=cambia-esto-por-otro-secreto-diferente
JWT_REFRESH_EXPIRES_IN=7d

# Cifrado AES-256 (exactamente 32 caracteres)
ENCRYPTION_KEY=clave-de-32-caracteres-exactos!!

# Rate limiting (requests por TTL en segundos)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Angular Frontend ──────────────────────────────────────────
FRONTEND_CONTAINER_NAME=angular-frontend
FRONTEND_IMAGE=angular-frontend:latest
FRONTEND_PORT=80

# URL del backend que usará Angular en producción
BACKEND_URL=http://localhost:3600
FRONTEND_URL=http://localhost:4200

# ── Red Docker ────────────────────────────────────────────────
NETWORK_NAME=app-network
